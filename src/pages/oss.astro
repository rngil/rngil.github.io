---
import PageLayout from "@/layouts/Base.astro";

type Role = "Author" | "Contributor";

interface SubProject {
	name: string;
	description: string;
	url: string;
}

interface Project {
	name: string;
	description: string;
	url: string;
	role: Role;
	children?: SubProject[];
}

const projects: Project[] = [
	{
		name: "InferOpt.jl",
		description: "Combinatorial optimization layers for machine learning pipelines",
		url: "https://github.com/JuliaDecisionFocusedLearning/InferOpt.jl",
		role: "Contributor",
	},
	{
		name: "MoleculeHub",
		description: "A Julia cheminformatics toolkit",
		url: "https://github.com/MoleculeHub",
		role: "Author",
		children: [
			{
				name: "MoleculeFlow.jl",
				description: "Core cheminformatics library",
				url: "https://github.com/MoleculeHub/MoleculeFlow.jl",
			},
			{
				name: "MoleculeView.jl",
				description: "Interactive molecular data visualization and exploration",
				url: "https://github.com/MoleculeHub/MoleculeView.jl",
			},
			{
				name: "MoleculeDatasets.jl",
				description: "Collection of cheminformatics datasets",
				url: "https://github.com/MoleculeHub/MoleculeDatasets.jl",
			},
			{
				name: "MoleculeScreen.jl",
				description: "Cheminformatics structural filters",
				url: "https://github.com/MoleculeHub/MoleculeScreen.jl",
			},
			{
				name: "MoleculeDock.jl",
				description: "Molecular docking",
				url: "https://github.com/MoleculeHub/MoleculeDock.jl",
			},
			{
				name: "OpenBabel.jl",
				description: "Julia bindings to Open Babel",
				url: "https://github.com/MoleculeHub/OpenBabel.jl",
			},
		],
	},
];
---

<PageLayout
	meta={{
		title: "Open Source",
		description: "Open source projects and contributions by Renee Gil.",
	}}
>
	<h1 class="text-muted mb-4 text-xs font-semibold uppercase tracking-widest">Open Source</h1>
	<p class="mb-10 max-w-prose">
		A selection of open-source projects I have authored or contributed to
	</p>
	<ul class="space-y-8" role="list">
		{
			projects.map((project) => (
				<li class="border-border border-t pt-6">
					<a
						class="cactus-link text-lg font-semibold"
						href={project.url}
						rel="noreferrer"
						target="_blank"
					>
						{project.name}
					</a>
					<p class="mt-1 mb-3 max-w-prose text-sm">{project.description}</p>
					<span class="bg-quote rounded px-2 py-0.5 font-mono text-xs text-black">
						{project.role}
					</span>
					{project.children && (
						<ul class="mt-4 space-y-3 border-l-2 border-border pl-4" role="list">
							{project.children.map((child) => (
								<li>
									<a
										class="cactus-link font-semibold"
										href={child.url}
										rel="noreferrer"
										target="_blank"
									>
										{child.name}
									</a>
									<p class="text-muted text-sm">{child.description}</p>
								</li>
							))}
						</ul>
					)}
				</li>
			))
		}
	</ul>
</PageLayout>
