---
import PageLayout from "@/layouts/Base.astro";

type Role = "Lead Developer" | "Contributor";

const projects: { name: string; description: string; url: string; role: Role }[] = [
	{
		name: "MoleculeHub",
		description: "A comprehensive set of cheminformatics tools in Julia",
		url: "https://github.com/MoleculeHub",
		role: "Lead Developer",
	},
];
---

<PageLayout
	meta={{
		title: "Open Source",
		description: "Open source projects and contributions by Renee Gil.",
	}}
>
	<h1 class="text-muted mb-4 text-xs font-semibold uppercase tracking-widest">Open Source</h1>
	<p class="mb-10 max-w-prose">
		A selection of open-source projects I maintain or contribute to
	</p>
	<ul class="space-y-8" role="list">
		{
			projects.map((project) => (
				<li class="border-border border-t pt-6">
					<a
						class="cactus-link text-lg font-semibold"
						href={project.url}
						rel="noreferrer"
						target="_blank"
					>
						{project.name}
					</a>
					<p class="mt-1 mb-3 max-w-prose text-sm">{project.description}</p>
					<span class="bg-quote rounded px-2 py-0.5 font-mono text-xs text-black">
						{project.role}
					</span>
				</li>
			))
		}
	</ul>
</PageLayout>
