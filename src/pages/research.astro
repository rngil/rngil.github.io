---
import PageLayout from "@/layouts/Base.astro";

const AUTHOR_ID = "2313058126";
const FIELDS = "title,year,venue,externalIds,abstract,openAccessPdf,publicationTypes";

interface S2Paper {
	paperId: string;
	title: string;
	year: number | null;
	venue: string | null;
	abstract: string | null;
	externalIds: Record<string, string> | null;
	openAccessPdf: { url: string } | null;
	publicationTypes: string[] | null;
}

const manualPapers: S2Paper[] = [
	{
		paperId: "manual-neurips-2023-gnn",
		title: "Graph Neural Networks for Identifying Protein-Reactive Compounds",
		year: 2023,
		venue: "NeurIPS 2023",
		abstract: null,
		externalIds: null,
		openAccessPdf: { url: "https://neurips.cc/virtual/2023/76241" },
		publicationTypes: ["Conference"],
	},
];

let papers: S2Paper[] = [];
try {
	const res = await fetch(
		`https://api.semanticscholar.org/graph/v1/author/${AUTHOR_ID}/papers?fields=${FIELDS}&limit=100`,
	);
	if (res.ok) {
		const json = (await res.json()) as { data: S2Paper[] };
		papers = json.data ?? [];
	}
} catch {
	// Fetch failed at build time — page renders without papers
}

const fetchedKeys = new Set(papers.map((p) => `${p.title}::${p.year}`));
for (const mp of manualPapers) {
	if (!fetchedKeys.has(`${mp.title}::${mp.year}`)) papers.push(mp);
}
papers.sort((a, b) => (b.year ?? 0) - (a.year ?? 0));

const groupedMap = new Map<string, S2Paper[]>();
for (const p of papers) {
	const group = groupedMap.get(p.title) ?? [];
	group.push(p);
	groupedMap.set(p.title, group);
}
const paperGroups = Array.from(groupedMap.values());

function paperUrl(paper: S2Paper): string {
	if (paper.openAccessPdf?.url) return paper.openAccessPdf.url;
	if (paper.externalIds?.DOI) return `https://doi.org/${paper.externalIds.DOI}`;
	if (paper.externalIds?.ArXiv) return `https://arxiv.org/abs/${paper.externalIds.ArXiv}`;
	return `https://www.semanticscholar.org/paper/${paper.paperId}`;
}

function badge(paper: S2Paper): string | null {
	if (paper.externalIds?.ArXiv) return "arXiv";
	const types = paper.publicationTypes ?? [];
	if (types.includes("JournalArticle")) return "Journal";
	if (types.includes("Conference")) return "Conference";
	if (types.includes("Preprint")) return "Preprint";
	if (types.includes("Book")) return "Book";
	if (types.includes("BookSection")) return "Book chapter";
	if (types.includes("Thesis")) return "Thesis";
	return null;
}

const lectures: { title: string; venue: string; year: number; ongoing?: boolean; url?: string }[] = [
	{
		title: "EPI 6101 — Course Lectures on Neural Networks",
		venue: "University of Ottawa",
		year: 2024,
		ongoing: true,
	},
];

---

<PageLayout
	meta={{
		title: "Research & Outreach",
		description: "Research in optimization, scientific computing, and health data privacy.",
	}}
>
	<h1 class="text-muted mb-4 text-xs font-semibold uppercase tracking-widest">Research Interests</h1>
	<p class="mb-10 max-w-prose">
		I am broadly interested in applying mathematics to difficult real-world problems.
		My work applies domains like scientific computing, optimization, operations research, and data science — 
		with applications spanning such fields as cheminformatics, energy market modelling, production scheduling, and health data privacy.
	</p>

	<section class="mb-12">
		<h2 class="title mb-6 text-xl">Papers & Preprints</h2>
		{
			papers.length === 0 ? (
				<p class="text-muted text-sm">Papers could not be loaded at build time.</p>
			) : (
				<ul class="space-y-6" role="list">
					{paperGroups.map((pubs) => {
						const single = pubs.length === 1;
						const first = pubs[0]!;
						return (
							<li class="border-border border-t pt-5">
								<a
									class="cactus-link font-semibold"
									href={paperUrl(first)}
									rel="noreferrer"
									target="_blank"
								>
									{first.title}
								</a>
								<div class="mt-1 flex items-center gap-x-2">
									{badge(first) && (
										<span class="bg-quote rounded px-1.5 py-0.5 font-mono text-xs text-black">
											{badge(first)}
										</span>
									)}
									<p class="text-muted text-sm">
										{[first.year, first.venue].filter(Boolean).join(" · ")}
									</p>
								</div>
								{!single && pubs.slice(1).map((pub) => {
									const label = badge(pub);
									return (
										<div class="mt-1 flex items-center gap-x-2">
											<p class="text-muted text-xs">Also presented at</p>
											{label && (
												<span class="bg-quote rounded px-1.5 py-0.5 font-mono text-xs text-black">
													{label}
												</span>
											)}
											<p class="text-muted text-sm">
												{[pub.year, pub.venue].filter(Boolean).join(" · ")}
											</p>
										</div>
									);
								})}
							</li>
						);
					})}
				</ul>
			)
		}
	</section>

	<section>
		<h2 class="title mb-6 text-xl">Teaching</h2>
		{
			lectures.length === 0 ? (
				<p class="text-muted text-sm">Guest lectures coming soon.</p>
			) : (
				<ul class="space-y-4" role="list">
					{lectures.map((lec) => (
						<li class="border-border border-t pt-4">
							{lec.url ? (
								<a class="cactus-link font-semibold" href={lec.url} rel="noreferrer" target="_blank">
									{lec.title}
								</a>
							) : (
								<span class="font-semibold">{lec.title}</span>
							)}
							<p class="text-muted mt-1 text-sm">
								{[lec.ongoing ? `${lec.year} – present` : lec.year, lec.venue].join(" · ")}
							</p>
						</li>
					))}
				</ul>
			)
		}
	</section>
</PageLayout>
