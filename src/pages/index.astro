---
import SocialList from "@/components/SocialList.astro";
import PageLayout from "@/layouts/Base.astro";
---

<PageLayout
	meta={{
		title: "Home",
		description: "Research engineer working at the intersection of algorithms, high-performance computing, and applied mathematics.",
	}}
>
	<section>
		<h1 class="text-muted mb-4 text-xs font-semibold uppercase tracking-widest">About</h1>
		<p class="text-accent mb-2 font-semibold">Research engineer & computational scientist</p>
		<p class="mb-8 max-w-prose">
			I'm a research engineer working at the intersection of algorithms, high-performance computing,
			and applied mathematics. I build scalable computational solutions to hard applied problems - 
			currently in data privacy, with a background spanning drug discovery, energy markets, and
			production scheduling.
		</p>
		<SocialList />
	</section>
</PageLayout>
