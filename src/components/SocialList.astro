---
import { Icon } from "astro-icon/components";

const socialLinks: {
	friendlyName: string;
	isWebmention?: boolean;
	link: string;
	name?: string;
	label?: string;
}[] = [
	{
		friendlyName: "GitHub",
		link: "https://github.com/rngil/",
		name: "mdi:github",
	},
	{
		friendlyName: "LinkedIn",
		link: "https://www.linkedin.com/in/reneegil/",
		name: "mdi:linkedin",
	},
	{
		friendlyName: "Semantic Scholar",
		link: "https://www.semanticscholar.org/author/Renee-Gil/2313058126",
		name: "semantic-scholar",
	},
	{
		friendlyName: "CV",
		link: "/cv.pdf",
		label: "CV",
	},
	{
		friendlyName: "Email",
		link: "mailto:renee.gil@mailbox.org",
		name: "mdi:email-outline",
	},
];
---

<div>
	<ul class="flex items-center gap-x-2">
		{
			socialLinks.map(({ friendlyName, isWebmention, link, name, label }) => (
				<li class="flex">
					<a
						class="hover:text-link inline-block"
						href={link}
						rel={`noreferrer ${isWebmention ? "me authn" : ""}`}
						target={link.startsWith("mailto:") ? undefined : "_blank"}
					>
						{label ? (
							<span aria-hidden="true" class="flex h-8 w-8 items-center justify-center font-mono text-xl font-bold">{label}</span>
						) : (
							<Icon aria-hidden="true" class="h-8 w-8" focusable="false" name={name!} />
						)}
						<span class="sr-only">{friendlyName}</span>
					</a>
				</li>
			))
		}
	</ul>
</div>
